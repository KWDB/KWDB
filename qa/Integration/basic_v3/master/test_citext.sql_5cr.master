> CREATE  PROCEDURE proc_citext_if_compare()
BEGIN
DECLARE
v CITEXT;
    set v = 'AbC';

    IF v = 'abc' THEN
        INSERT INTO proc_citext_log VALUES ('eq_true');
ELSE
        INSERT INTO proc_citext_log VALUES ('eq_false');
    ENDIF;
END ;
