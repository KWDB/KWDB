> CREATE PROCEDURE proc_citext_null()
BEGIN
DECLARE
v CITEXT;
    set v = NULL;

    IF v IS NULL THEN
        INSERT INTO proc_citext_log VALUES ('null_ok');
ELSE
        INSERT INTO proc_citext_log VALUES ('null_bad');
    ENDIF;
END ;
