> CREATE TABLE caster (
                        citext      citext,
                        text        text,
                        varchar     varchar,
                        bpchar      bpchar,
                        char        char,
                        chr         "char",
                        name        name,
                        bytea       bytea,
                        boolean     boolean,
                        float4      float4,
                        float8      float8,
                        numeric     numeric,
                        int8        int8,
                        int4        int4,
                        int2        int2,
                        inet        inet,
                        timestamp   timestamp,
                        timestamptz timestamptz,
                        interval    interval,
                        date        date,
                        time        time,
                        timetz      timetz,
                        bit         bit,
                        bitv        bit varying,
                        uuid        uuid
);
