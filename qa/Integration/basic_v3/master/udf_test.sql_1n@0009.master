> CREATE FUNCTION check_substring(str nchar(10), substr nchar(10))
    RETURNs int
    LANGUAGE LUA
BEGIN
'
function check_substring(str, substr)
    local start_pos, end_pos = string.find(str, substr)
    if start_pos then
        return start_pos
    else
        return -1
    end
end
'
END;
