> select a.bucket,a.temp_filled as linear_filled,b.temp_filled as const_filled,a.temp_filled - b.temp_filled as diff from (select time_bucket_gapfill(k_timestamp,'5m') as bucket,interpolate(avg(temperature),'linear') as temp_filled from test_join.tb where k_timestamp >= '2026-04-20 16:00:00' and k_timestamp < '2026-04-20 16:30:00' group by bucket) a join (select time_bucket_gapfill(k_timestamp,'5m') as bucket,interpolate(avg(temperature),'0') as temp_filled from test_join.tb where k_timestamp >= '2026-04-20 16:00:00' and k_timestamp < '2026-04-20 16:30:00' group by bucket) b on a.bucket = b.bucket order by a.bucket;
