#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
SKILL_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
CALLER_CWD=$(pwd)

if command -v go >/dev/null 2>&1; then
  cd "$SKILL_DIR"
  export GOCACHE="${AI_PR_GOCACHE:-${TMPDIR:-/tmp}/kwdb-ai-pr-go-cache}"
  export AI_PR_CALLER_CWD="$CALLER_CWD"
  exec go run ./cmd/ai-pr "$@"
fi

echo "go is required to run .agents/skills/ai-pr-kb-usage/scripts/ai-pr because this skill executes via go run." >&2
exit 1
